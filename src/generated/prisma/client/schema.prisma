generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "mysql"
}

model ServerSetting {
  id String @id @default(cuid())

  // DiscordサーバーID
  serverId String @unique

  // オプトアウト設定
  spamBlockEnabled   Boolean @default(true)
  inviteBlockEnabled Boolean @default(true)

  // 報告先チャンネル
  spamReportChannelId   String?
  inviteReportChannelId String?

  // 除外設定（スパムブロック用）
  spamIgnoredRoles    String @default("") @db.Text
  spamIgnoredChannels String @default("") @db.Text

  // 除外設定（招待リンクブロック用）
  inviteIgnoredRoles    String @default("") @db.Text
  inviteIgnoredChannels String @default("") @db.Text

  // ハニーポット設定
  honeypotEnabled    Boolean @default(false)
  honeypotChannelId  String?
  honeypotReportId   String?
  honeypotIgnoreRole String  @default("") @db.Text

  // 互換性のために残す
  ignoredRoles    String @default("") @db.Text
  ignoredChannels String @default("") @db.Text

  // メタ情報
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  expiresAt             DateTime? @db.DateTime(0)
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}
