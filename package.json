{
	"name": "sirius-system",
	"version": "1.0.0",
	"description": "Discord bot for Sirius project",
	"type": "module",
	"private": true,
	"main": "index.ts",
	"scripts": {
		"dev": "npx tsx --tsconfig ./tsconfig.json src/index.ts",
		"build": "npx tsc",
		"start": "node dist/index.js",
		"lint": "biome check . --fix",
		"format": "biome format . --write"
	},
	"dependencies": {
		"@discordjs/voice": "^0.19.2",
		"@prisma/adapter-mariadb": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"discord.js": "^14.25.1",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"ffmpeg": "^0.0.4",
		"google-tts-api": "^2.0.2",
		"libsodium-wrappers": "^0.8.2",
		"mysql2": "^3.20.0",
		"node-fetch": "^3.3.2",
		"tweetnacl": "^1.0.3"
	},
	"overrides": {
		"undici": "^6.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/express": "^5.0.6",
		"@types/node": "^22.19.19",
		"prisma": "^7.8.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
