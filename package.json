{
	"name": "sirius-system",
	"version": "1.0.0",
	"description": "Discord bot for Sirius project",
	"type": "module",
	"private": true,
	"main": "index.ts",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun run src/index.ts",
		"build": "bun build src/index.ts --outdir dist --minify",
		"lint": "biome check . --fix",
		"format": "biome format . --write"
	},
	"dependencies": {
		"discord.js": "^14.25.1",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"mysql2": "^3.20.0",
		"node-fetch": "^3.3.2",
		"tweetnacl": "^1.0.3"
	},
	"overrides": {
		"undici": "^6.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/express": "^5.0.6",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
