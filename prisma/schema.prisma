generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model SurvivalRanking {
  userId    String   @id
  username  String
  bestDays  Int      @default(0)

  updatedAt DateTime @updatedAt
}

model ServerSetting {
  id String @id @default(cuid())

  // DiscordサーバーID（実質ユニークキー）
  serverId String @unique

  // オプトアウト設定
  spamBlockEnabled    Boolean @default(true)
  inviteBlockEnabled  Boolean @default(true)

  // 報告先チャンネル
  spamReportChannelId   String?
  inviteReportChannelId String?

  // メタ情報（任意）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
